---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Evaluation framework for LLM music notation analysis" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=Geist+Mono:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (function() {
        var t = 'light';
        if (t === 'light') document.documentElement.classList.add('light');
      })();
    </script>
    <title>{title} | Music LLM Eval</title>
  </head>
  <body class="min-h-screen antialiased">
    <slot />
  </body>
</html>

<style>
  @import '../styles/global.css';
</style>
